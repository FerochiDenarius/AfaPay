NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/afapay
API_PUBLIC_URL=https://afapay.xyz

ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
PHONE_OTP_ENABLED=false

RESEND_API_KEY=re_replace-with-resend-api-key
EMAIL_FROM="AfaPay <noreply@afapay.xyz>"

EMAIL_CODE_LIFETIME=600
EMAIL_RESEND_COOLDOWN=60
CORS_ORIGIN=https://afapay.xyz,https://www.afapay.xyz

# Media storage
# Use "local" while setting up Google Cloud Storage. Use "gcs" in production.
MEDIA_STORAGE_PROVIDER=local
LOCAL_MEDIA_ROOT=./uploads/media
LOCAL_MEDIA_PUBLIC_BASE_URL=https://afapay.xyz/media

# Google Cloud Storage production settings
GOOGLE_CLOUD_PROJECT=afapay
GCS_MEDIA_BUCKET=afapay-media
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/afapay-media
# Paste the compact service account JSON as one line in Railway/local env.
GCS_SERVICE_ACCOUNT_JSON=
# Keep this false when the bucket has bucket-level public read. Set true only
# if using object ACLs with uniform bucket-level access disabled.
GCS_MAKE_PUBLIC=false
